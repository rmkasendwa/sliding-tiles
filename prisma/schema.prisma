generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                              String        @id @default(cuid())
  name                            String
  username                        String        @unique(map: "users_username_key")
  /// Case-insensitive uniqueness is enforced by the users_email_lower_key expression index.
  email                           String
  passwordHash                    String        @map("password_hash")
  emailVerifiedAt                 DateTime?     @map("email_verified_at")
  emailVerificationTokenHash      String?       @unique(map: "users_email_verification_token_hash_key") @map("email_verification_token_hash")
  emailVerificationTokenExpiresAt DateTime?     @map("email_verification_token_expires_at")
  verificationEmailSentAt         DateTime?     @map("verification_email_sent_at")
  resetPasswordTokenHash          String?       @map("reset_password_token_hash")
  resetPasswordTokenExpiresAt     DateTime?     @map("reset_password_token_expires_at")
  createdAt                       DateTime      @default(now()) @map("created_at")
  updatedAt                       DateTime      @updatedAt @map("updated_at")
  gameState                       GameState?
  scores                          Leaderboard[]

  @@map("users")
}

model GameState {
  id        String   @id @default(cuid())
  userId    String   @unique(map: "game_states_user_id_key") @map("user_id")
  level     Int
  board     Json
  moves     Int
  startedAt DateTime @map("started_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "game_states_user_id_fkey")

  @@map("game_states")
}

model Leaderboard {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  level        Int
  moves        Int
  timeSeconds  Int      @map("time_seconds")
  attemptType  String   @default("original") @map("attempt_type")
  replayOfId   String?  @map("replay_of_id")
  puzzleConfig Json?    @map("puzzle_config")
  completedAt  DateTime @default(now()) @map("completed_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "leaderboards_user_id_fkey")

  @@index([level, timeSeconds, moves], map: "leaderboards_level_time_seconds_moves_idx")
  @@index([replayOfId], map: "leaderboards_replay_of_id_idx")
  @@index([userId, completedAt], map: "leaderboards_user_id_completed_at_idx")
  @@map("leaderboards")
}

model AnonymousAnalyticsEvent {
  id                String   @id @default(cuid())
  anonymousPlayerId String   @map("anonymous_player_id")
  sessionId         String   @map("session_id")
  eventName         String   @map("event_name")
  level             Int?
  puzzleSize        String?  @map("puzzle_size")
  moveCount         Int?     @map("move_count")
  timerValueMs      Int?     @map("timer_value_ms")
  occurredAt        DateTime @map("occurred_at")
  screenWidth       Int?     @map("screen_width")
  screenHeight      Int?     @map("screen_height")
  userAgent         String?  @map("user_agent")
  createdAt         DateTime @default(now()) @map("created_at")

  @@index([anonymousPlayerId, occurredAt], map: "anonymous_analytics_events_player_occurred_at_idx")
  @@index([eventName, occurredAt], map: "anonymous_analytics_events_name_occurred_at_idx")
  @@index([sessionId], map: "anonymous_analytics_events_session_id_idx")
  @@map("anonymous_analytics_events")
}

{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "monorepo": true,
  "projects": {
    "api": {
      "entryFile": "main",
      "root": "apps/api",
      "sourceRoot": "apps/api/src",
      "type": "application",
      "compilerOptions": {
        "deleteOutDir": true,
        "tsConfigPath": "apps/api/tsconfig.build.json"
      }
    }
  }
}

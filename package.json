{
  "name": "sliding-tiles",
  "version": "2.0.0",
  "private": true,
  "author": "Ronald M. Kasendwa",
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "web:dev": "next dev apps/web",
    "web:build": "next build apps/web",
    "web:start": "next start apps/web",
    "web:typecheck": "tsc --noEmit -p apps/web/tsconfig.json",
    "api:build": "nest build api",
    "api:dev": "nest start api --watch",
    "api:start": "nest start api",
    "build": "npm run db:generate && npm run api:build && npm run web:build",
    "start": "npm run web:start",
    "lint": "eslint .",
    "typecheck": "npm run web:typecheck && tsc --noEmit -p apps/api/tsconfig.json",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "docker:build": "docker build -t sliding-tiles:latest .",
    "docker:up": "docker compose --profile app up",
    "docker:down": "docker compose --profile app down"
  },
  "overrides": {
    "@hono/node-server": "1.19.13",
    "postcss": "8.5.15"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.24",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.24",
    "@nestjs/platform-express": "^11.1.24",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "bcryptjs": "^3.0.0",
    "dotenv": "^16.4.7",
    "jose": "^6.0.0",
    "lucide-react": "^1.16.0",
    "next": "^16.0.0",
    "pg": "^8.13.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "server-only": "^0.0.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.0.0",
    "prisma": "^7.0.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.8.0"
  }
}
